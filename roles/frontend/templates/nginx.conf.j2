location /images/ {
    expires 5s;
    root /usr/share/nginx/html;
    try_files $uri /images/placeholder.jpg;
}

location /api/catalogue/ {
    proxy_pass http://catalogue.janadevops.online:8080/;
}

location /api/user/ {
    proxy_pass http://user.janadevops.online:8080/;
}

location /api/cart/ {
    proxy_pass http://cart.janadevops.online:8080/;
}

location /api/shipping/ {
    proxy_pass http://shipping.janadevops.online:8080/;
}

location /api/payment/ {
    proxy_pass http://payment.janadevops.online:8080/;
}

location /health {
    stub_status on;
    access_log off;
}